#!/usr/bin/env python3
"""
Mingo System Orchestrator (Seed Script)
This is the entry point for the mingo-system management.
"""

import sys
import os

# Add src to path so we can import our manager
sys.path.append(os.path.join(os.path.dirname(__file__), "src/mingo-manager/src"))

try:
    from mingo_manager.cli import main
except ImportError:
    # Fallback while we transition from git_protocol
    try:
        from git_protocol.cli import main
        print("[INFO] Using legacy git_protocol engine...")
    except ImportError:
        print("[ERROR] Mingo Manager or Git Protocol not found.")
        sys.exit(1)

if __name__ == "__main__":
    main()
