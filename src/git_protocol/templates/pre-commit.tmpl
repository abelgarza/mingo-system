#!/usr/bin/env bash
# git-protocol pre-commit hook: Secret Scanner

if git diff --cached --name-only | xargs -r grep -E 'ghp_[A-Za-z0-9]{36}|github_pat_[a-zA-Z0-9_]{82}'; then
    echo ""
    echo "ERROR: GitHub Personal Access Token detected in staged files! "
    echo "Commit rejected to prevent leaking secrets."
    exit 1
fi
exit 0
